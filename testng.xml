<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Ombudsman" parallel="methods" thread-count="4">
	<listeners>
		<listener class-name="com.ombudsman.listeners.TestListner"></listener>
	</listeners>
	<!-- Chrome -->
	<test name="Chrome Tests">
	  <parameter name="browser" value="chrome"/>
		<classes>
			<class name="com.ombudsman.test.ui.RegisterTest" />
			<class name="com.ombudsman.test.ui.LandingPageTest" />
		</classes>
	</test>
	<!-- Firefox -->
	<test name="Firefox Tests">
	  <parameter name="browser" value="firefox"/>
		<classes>
			<class name="com.ombudsman.test.ui.RegisterTest" />
			<class name="com.ombudsman.test.ui.LandingPageTest" />
		</classes>
	</test>
</suite>